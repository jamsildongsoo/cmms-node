# =========================================================================
# CMMS-node 루트 .gitignore
# =========================================================================

# 환경변수 / 시크릿
#  - 루트 백엔드 시크릿 '.env'와 모든 *.local 만 제외
#  - frontend/.env.development 등 비밀 아닌 Vite 공개 설정(VITE_*)은 커밋 유지
.env
.env.local
.env.*.local
*.local
!.env.template

# 의존성
node_modules/
**/node_modules/

# 빌드 산출물
dist/
build/
**/dist/

# 로그 / 임시
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store

# 에디터/IDE
.idea/
.vscode/
*.swp
