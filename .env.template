# =========================================================================
# CMMS 환경변수 템플릿 (.env.template) — Git 커밋됨 (값 없음, 키 가이드용)
# =========================================================================
# 개발/운영 모두 루트 `.env` 파일명을 사용합니다.
# 이 파일을 복사해 각 환경의 `.env`를 만들고 실제 값을 채우세요.
#   cp .env.template .env
#
# 개발 서버 `.env`: NODE_ENV=development, DB_SYNCHRONIZE=true
# 운영 서버 `.env`: NODE_ENV=production, DB_SYNCHRONIZE=false
#
# 모든 자격증명은 환경변수로만 주입됩니다(코드에 기본 시크릿 없음).
# JWT_SECRET, DB 접속정보 미설정 시 애플리케이션이 기동되지 않습니다(fail-fast).

# -------------------------------------------------------------------------
# 애플리케이션
# -------------------------------------------------------------------------
# NODE_ENV: development | production (운영 서버에서는 production)
NODE_ENV=development
# API 리슨 포트 (기본 8080)
PORT=8080

# -------------------------------------------------------------------------
# 컨테이너 이미지 (운영 docker-compose.prod.yml = 레지스트리 pull)
# -------------------------------------------------------------------------
# CI가 빌드/푸시한 이미지를 서버가 pull. IMAGE_REGISTRY 미설정 시 compose가 즉시 실패(fail-fast).
IMAGE_REGISTRY=ghcr.io/your-org
# 배포 태그(미설정 시 latest). 운영은 불변 태그(커밋SHA 등) 권장
# IMAGE_TAG=latest

# -------------------------------------------------------------------------
# Database (Supabase PostgreSQL — Session Pooler, port 5432)
# -------------------------------------------------------------------------
# Schema 격리 (dev / prod):
#   Supabase 프로젝트 내 schema를 생성한 뒤, URL의 search_path로 타겟을 지정합니다.
#   ⚠️ 개발 .env의 search_path를 prod로 설정하지 마세요 — DB_SYNCHRONIZE=true가 운영 schema를 훼손합니다.

# 개발 환경 (search_path=dev)
DB_URL=postgresql://[YOUR-POOLER-HOST]:5432/postgres?sslmode=require&options=-c%20search_path%3Ddev

# 운영 환경 (아래 주석을 풀고 사용 — search_path=prod)
# DB_URL=postgresql://[YOUR-POOLER-HOST]:5432/postgres?sslmode=require&options=-c%20search_path%3Dprod

# 풀러 username 형식: postgres.<project-ref>
DB_USERNAME=postgres.[YOUR-PROJECT-REF]
DB_PASSWORD=

# 개발 전용: 엔티티 → DB 스키마 자동 반영(TypeORM synchronize).
#   운영(NODE_ENV=production)에선 코드가 강제 무시 — 운영 DDL은 별도 마이그레이션으로 관리.
#   ⚠️ search_path=prod 상태에서 true이면 운영 schema가 훼손됩니다.
DB_SYNCHRONIZE=true

# -------------------------------------------------------------------------
# JWT (필수)
# -------------------------------------------------------------------------
# 생성: openssl rand -base64 32   (운영/개발 환경마다 서로 다른 키 사용)
JWT_SECRET=
# 토큰 만료 — 단위: 초 (기본 1800 = 30분)
# JWT_EXPIRATION=1800

# -------------------------------------------------------------------------
# 비밀번호 정책 (선택, 미설정 시 기본값 사용)
# -------------------------------------------------------------------------
# 비밀번호 만료 일수(경과 시 변경 강제)
# PASSWORD_EXPIRY_DAYS=90
# 계정 잠금까지 허용하는 연속 실패 횟수
# PASSWORD_MAX_FAILED=5
# 잠금 지속 시간(분)
# PASSWORD_LOCK_MINUTES=30

# -------------------------------------------------------------------------
# Object Storage (Supabase S3 호환) — 첨부파일 업로드
# -------------------------------------------------------------------------
STORAGE_ENDPOINT=https://[YOUR-PROJECT-REF].supabase.co/storage/v1/s3
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=cmms-node-attachments
# STORAGE_REGION=ap-southeast-1

# 고아 파일 정리(reconcile) 배치 (선택, 기본 비활성)
# true일 때만 동작
# STORAGE_RECONCILE_ENABLED=false
# 실행 스케줄(기본 매일 04:00)
# STORAGE_RECONCILE_CRON=0 0 4 * * *
# 이 시간 이내 생성 파일은 정리 제외
# STORAGE_RECONCILE_GRACE_HOURS=24

# -------------------------------------------------------------------------
# 파일 업로드 제한
# -------------------------------------------------------------------------
# 단일 파일 최대 크기(MB)
FILE_MAX_SIZE_MB=10
# 한 번에 업로드 가능한 최대 파일 수
FILE_MAX_COUNT=10
# 허용 MIME 타입 (쉼표 구분, image/*는 와일드카드)
# .hwp: application/x-hwp, application/vnd.hancom.hwp, application/haansofthwp
# .hwpx: application/hwp+zip, application/vnd.hancom.hwpx, application/octet-stream
STORAGE_ALLOWED_MIMES=image/*,application/pdf,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/msword,application/vnd.openxmlformats-officedocument.presentationml.presentation,application/vnd.ms-powerpoint,application/x-hwp,application/vnd.hancom.hwp,application/haansofthwp,application/hwp+zip,application/vnd.hancom.hwpx,application/octet-stream,application/zip,application/x-zip-compressed
